{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/forms/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Helvetica Now Display|PP Formula Condensed|Manic))/i]",
        "message": "Font not provided by the design system. Available: Helvetica Now Display, PP Formula Condensed, Manic."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|href|onClick|type|disabled|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, href, onClick, type, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:red|black|white)$/]",
        "message": "<Button> variant must be one of 'red' | 'black' | 'white'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:default|large)$/]",
        "message": "<Button> size must be one of 'default' | 'large'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='FormField'] > JSXAttribute > JSXIdentifier[name!=/^(?:type|label|placeholder|value|onChange|options|theme|required|name|rows|key|ref|className|style|children)$/]",
        "message": "<FormField> doesn't accept that prop. Declared props: type, label, placeholder, value, onChange, options, theme, required, name, rows."
      },
      {
        "selector": "JSXOpeningElement[name.name='FormField'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:text|email|textarea|select|checkbox)$/]",
        "message": "<FormField> type must be one of 'text' | 'email' | 'textarea' | 'select' | 'checkbox'."
      },
      {
        "selector": "JSXOpeningElement[name.name='FormField'] > JSXAttribute[name.name='theme'] > Literal[value!=/^(?:dark|light)$/]",
        "message": "<FormField> theme must be one of 'dark' | 'light'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Headline'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|size|tag|color|subHeadline|key|ref|className|style|children)$/]",
        "message": "<Headline> doesn't accept that prop. Declared props: children, size, tag, color, subHeadline."
      },
      {
        "selector": "JSXOpeningElement[name.name='Headline'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:3xlarge|2xlarge|xlarge|large|medium|small|h1|h2|h3|h4|h5|h6)$/]",
        "message": "<Headline> size must be one of '3xlarge' | '2xlarge' | 'xlarge' | 'large' | 'medium' | 'small' | 'h1' | 'h2' | 'h3' | 'h4' | 'h5' | 'h6'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {
      "Button": {
        "replaces": []
      },
      "FormField": {
        "replaces": []
      },
      "Headline": {
        "replaces": []
      }
    },
    "tokens": [
      "--border-radius-button",
